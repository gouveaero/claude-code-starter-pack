import React from "react";
import { AbsoluteFill, Series, Audio, Sequence, staticFile } from "remotion";
import { TransitionSeries, linearTiming } from "@remotion/transitions";
import { fade } from "@remotion/transitions/fade";
import { slide } from "@remotion/transitions/slide";
import { wipe } from "@remotion/transitions/wipe";
import { loadFont as loadInter } from "@remotion/google-fonts/Inter";
import { VideoCut } from "./components/VideoCut";
import { KineticCaption } from "./components/KineticCaption";
import { StatOverlay } from "./components/StatOverlay";
import { StatChart } from "./components/StatChart";
import { StatBarChart } from "./components/StatBarChart";
import { StatStackedBar } from "./components/StatStackedBar";
import { CascadeGraphic } from "./components/CascadeGraphic";
import { LogoBug } from "./components/LogoBug";
// — snippet imports (conditional — build_remotion.py removes unused lines) —
import { CountUp } from "./components/snippets/CountUp";
import { KenBurns } from "./components/snippets/KenBurns";
import { GlitchText } from "./components/snippets/GlitchText";
import { CalloutArrow } from "./components/snippets/CalloutArrow";
import { LowerThird } from "./components/snippets/LowerThird";
import { PiPBroll } from "./components/snippets/PiPBroll";
import { RichOverlayRenderer, RichOverlayDef } from "./components/RichOverlays";

// Type-safe Google Fonts load — Inter Black/ExtraBold for captions and stats.
// Resolves FOUT (flash of unstyled text) by waiting for font before render.
const { fontFamily: INTER_FONT } = loadInter("normal", {
  weights: ["800", "900"],
  subsets: ["latin", "latin-ext"],
});

// Auto-generated by build_remotion.py — do not edit by hand.

type Cut = {
  clip: string;
  source_in: number;
  source_out: number;
  timeline_start?: number;
  rationale?: string;
  zoom?: number;
  y_offset?: number;
};

type Transition = {
  after_cut_index: number;
  type: "fade" | "slide_up" | "wipe" | "none";
  duration_frames: number;
};

type CaptionWord = { text: string; start: number; end: number; emphasis?: "keyword" | "emphasis" | "normal" };

type Caption = {
  text?: string;
  words?: CaptionWord[];
  start: number;
  end: number;
  style?: "highlight_accent" | "highlight_box" | "minimal";
  emphasis?: "keyword" | "emphasis" | "normal";
};

type Overlay = {
  text: string;
  subtext?: string;
  start: number;
  end: number;
};

type StatChartCfg = {
  variant?: "circular" | "bar" | "stacked";
  value?: number;
  prefix?: string;
  label?: string;
  position?: "center" | "top" | "bottom" | "top-right" | "top-left";
  segments?: { label: string; value: number; color?: string }[];
  total?: number;
  start: number;
  end: number;
};

type GraphicCfg = {
  type: "cascade";
  values: string[];
  position?: "center" | "top" | "bottom";
  start: number;
  end: number;
};

// Snippet overlay types — driven by edit_plan.json "snippet_overlays" array
type SnippetOverlay =
  | { kind: "count_up";     start: number; end: number; target: number; prefix?: string; suffix?: string; fontSize?: number; color?: string; accentColor?: string }
  | { kind: "ken_burns";    start: number; end: number; src: string; zoomFrom?: number; zoomTo?: number; panX?: number; panY?: number }
  | { kind: "glitch_text";  start: number; end: number; text: string; fontSize?: number; color?: string; intensity?: number; durationFrames?: number }
  | { kind: "callout";      start: number; end: number; label: string; targetX: number; targetY: number; direction?: "left" | "right" | "up" | "down"; color?: string; fontSize?: number }
  | { kind: "lower_third";  start: number; end: number; name: string; detail?: string; accentColor?: string; bgColor?: string; textColor?: string; positionY?: number }
  | { kind: "pip_broll";    start: number; end: number; src: string; corner?: "top-left" | "top-right" | "bottom-left" | "bottom-right"; sizePercent?: number; borderColor?: string; startFrom?: number };

type Sfx = {
  category: string;
  at_ms: number;
  intent?: string;
  volume_db?: number;
  file?: string;           // populated by build_remotion.py
  duration_cap_ms?: number; // populated by build_remotion.py
  duration_ms?: number;    // optional manual override
};

type Music = {
  file: string;
  start_ms?: number;
  end_ms?: number;
  volume_db?: number;
  fade_in_ms?: number;
  fade_out_ms?: number;
};

type Plan = {
  name: string;
  fps: number;
  v1_main: Cut[];
  transitions?: Transition[];
  subtitle_track: Caption[];
  overlays_v2?: Overlay[];
  stat_charts?: StatChartCfg[];
  graphics?: GraphicCfg[];
  snippet_overlays?: SnippetOverlay[];
  rich_overlays?: RichOverlayDef[];
  audio_sync_beats?: number[];
  sfx?: Sfx[];
  music?: Music[];
  color_correction?: { css_filter?: string };
};

// dB → linear gain. -10dB ≈ 0.316, -6dB ≈ 0.5, 0dB = 1.0
const dbToLinear = (db: number): number => Math.pow(10, db / 20);

type BrandConfig = {
  brand?: {
    accent_color?: string;
    text_color?: string;
    primary_color?: string;
    background_color?: string;
    font_family?: string;
    logo?: string;
  };
  remotion?: {
    logo_bug?: {
      enabled?: boolean;
      position?: "top-right" | "top-left" | "bottom-right" | "bottom-left";
      opacity?: number;
    };
    css_filter?: string;
  };
};

export const Reel: React.FC<{ plan: Plan; brand: BrandConfig }> = ({
  plan,
  brand,
}) => {
  const fps = plan.fps || {{FPS}};
  const cssFilter = plan.color_correction?.css_filter ?? brand.remotion?.css_filter;
  const transitionsByIndex = new Map<number, Transition>();
  for (const t of plan.transitions ?? []) {
    if (t.type !== "none") transitionsByIndex.set(t.after_cut_index, t);
  }

  const presentationFor = (t: Transition) => {
    if (t.type === "fade") return fade();
    if (t.type === "slide_up") return slide({ direction: "from-bottom" });
    if (t.type === "wipe") return wipe();
    return fade();
  };

  const brandColors = {
    keyword: brand.brand?.accent_color ?? "#B87333",
    emphasis: "#F5C83C",
    normal: brand.brand?.text_color ?? "#FFFFFF",
    stroke: brand.brand?.background_color ?? "#0A0A0A",
  };
  const fontFamily = brand.brand?.font_family ?? "Inter";

  const cuts = plan.v1_main;

  return (
    <AbsoluteFill style={{ backgroundColor: "#000" }}>
      <TransitionSeries>
        {cuts.map((cut, i) => {
          const durationInFrames = Math.max(
            1,
            Math.round((cut.source_out - cut.source_in) * fps)
          );
          const trans = transitionsByIndex.get(i);
          const prevTrans = transitionsByIndex.get(i - 1);
          const audioFadeIn = prevTrans?.duration_frames ?? 3;
          const audioFadeOut = trans?.duration_frames ?? 3;
          return (
            <React.Fragment key={`cut-${i}`}>
              <TransitionSeries.Sequence durationInFrames={durationInFrames}>
                <VideoCut
                  clip={cut.clip}
                  sourceIn={cut.source_in}
                  sourceOut={cut.source_out}
                  cssFilter={cssFilter}
                  zoom={cut.zoom ?? 1.22}
                  yOffset={cut.y_offset ?? -5}
                  audioFadeIn={audioFadeIn}
                  audioFadeOut={audioFadeOut}
                />
              </TransitionSeries.Sequence>
              {trans && i < cuts.length - 1 ? (
                <TransitionSeries.Transition
                  presentation={presentationFor(trans)}
                  timing={linearTiming({
                    durationInFrames: trans.duration_frames || 6,
                  })}
                />
              ) : null}
            </React.Fragment>
          );
        })}
      </TransitionSeries>

      {(plan.subtitle_track ?? []).map((c, i) => (
        <KineticCaption
          key={`cap-${i}`}
          words={c.words}
          text={c.text}
          start={c.start}
          end={c.end}
          style={c.style}
          brandColors={brandColors}
          fontFamily={INTER_FONT}
        />
      ))}

      {(plan.overlays_v2 ?? []).map((o, i) => (
        <StatOverlay
          key={`stat-${i}`}
          text={o.text}
          subtext={o.subtext}
          start={o.start}
          end={o.end}
          brandColors={brandColors}
          fontFamily={INTER_FONT}
        />
      ))}

      {(plan.stat_charts ?? []).map((s, i) => {
        const variant = s.variant ?? "circular";
        const position = s.position ?? "top";
        if (variant === "bar") {
          return (
            <StatBarChart
              key={`chart-${i}`}
              value={s.value ?? 0}
              prefix={s.prefix}
              label={s.label}
              start={s.start}
              end={s.end}
              position={position as any}
              brandColors={brandColors}
              fontFamily={INTER_FONT}
            />
          );
        }
        if (variant === "stacked") {
          return (
            <StatStackedBar
              key={`chart-${i}`}
              segments={s.segments ?? []}
              total={s.total ?? (s.segments ?? []).reduce((a, x) => a + x.value, 0)}
              prefix={s.prefix}
              label={s.label}
              start={s.start}
              end={s.end}
              position={position as any}
              brandColors={brandColors}
              fontFamily={INTER_FONT}
            />
          );
        }
        return (
          <StatChart
            key={`chart-${i}`}
            value={s.value ?? 0}
            prefix={s.prefix}
            label={s.label}
            start={s.start}
            end={s.end}
            position={position}
            brandColors={brandColors}
            fontFamily={INTER_FONT}
          />
        );
      })}

      {(plan.graphics ?? []).map((g, i) => {
        if (g.type === "cascade") {
          return (
            <CascadeGraphic
              key={`graphic-${i}`}
              values={g.values}
              start={g.start}
              end={g.end}
              position={g.position ?? "top"}
              brandColors={brandColors}
              fontFamily={INTER_FONT}
            />
          );
        }
        return null;
      })}

      {/* ── Snippet overlays ── driven by plan.snippet_overlays[] */}
      {(plan.snippet_overlays ?? []).map((s, i) => {
        const key = `snip-${i}`;
        const startFrame = Math.round(s.start * fps);
        const durationFrames = Math.max(1, Math.round((s.end - s.start) * fps));

        if (s.kind === "count_up") {
          return (
            <Series.Sequence key={key} from={startFrame} durationInFrames={durationFrames} layout="none">
              <CountUp
                target={s.target}
                prefix={s.prefix}
                suffix={s.suffix}
                durationFrames={durationFrames}
                fontSize={s.fontSize}
                color={s.color}
                accentColor={s.accentColor}
              />
            </Series.Sequence>
          );
        }
        if (s.kind === "ken_burns") {
          return (
            <Series.Sequence key={key} from={startFrame} durationInFrames={durationFrames} layout="none">
              <KenBurns
                src={s.src}
                durationFrames={durationFrames}
                zoomFrom={s.zoomFrom}
                zoomTo={s.zoomTo}
                panX={s.panX}
                panY={s.panY}
              />
            </Series.Sequence>
          );
        }
        if (s.kind === "glitch_text") {
          return (
            <Series.Sequence key={key} from={startFrame} durationInFrames={durationFrames} layout="none">
              <GlitchText
                text={s.text}
                fontSize={s.fontSize}
                color={s.color}
                intensity={s.intensity}
                durationFrames={s.durationFrames ?? durationFrames}
              />
            </Series.Sequence>
          );
        }
        if (s.kind === "callout") {
          return (
            <Series.Sequence key={key} from={startFrame} durationInFrames={durationFrames} layout="none">
              <CalloutArrow
                label={s.label}
                targetX={s.targetX}
                targetY={s.targetY}
                direction={s.direction}
                color={s.color}
                fontSize={s.fontSize}
              />
            </Series.Sequence>
          );
        }
        if (s.kind === "lower_third") {
          return (
            <Series.Sequence key={key} from={startFrame} durationInFrames={durationFrames} layout="none">
              <LowerThird
                name={s.name}
                detail={s.detail}
                accentColor={s.accentColor}
                bgColor={s.bgColor}
                textColor={s.textColor}
                positionY={s.positionY}
              />
            </Series.Sequence>
          );
        }
        if (s.kind === "pip_broll") {
          return (
            <Series.Sequence key={key} from={startFrame} durationInFrames={durationFrames} layout="none">
              <PiPBroll
                src={s.src}
                corner={s.corner}
                sizePercent={s.sizePercent}
                borderColor={s.borderColor}
                startFrom={s.startFrom}
              />
            </Series.Sequence>
          );
        }
        return null;
      })}

      {/* ── Rich overlays — director-level animations driven by plan.rich_overlays[] */}
      {(plan.rich_overlays ?? []).map((overlay, i) => {
        const startFrame = Math.round(overlay.start * fps);
        const endFrame = Math.round(overlay.end * fps);
        const durationFrames = Math.max(1, endFrame - startFrame);
        return (
          <Series.Sequence key={`rich-${i}`} from={startFrame} durationInFrames={durationFrames} layout="none">
            <RichOverlayRenderer overlay={overlay} fps={fps} />
          </Series.Sequence>
        );
      })}

      {brand.remotion?.logo_bug?.enabled && brand.brand?.logo ? (
        <LogoBug
          logoSrc={brand.brand.logo}
          position={brand.remotion.logo_bug.position ?? "top-right"}
          opacity={brand.remotion.logo_bug.opacity ?? 0.7}
        />
      ) : null}

      {/* ── SFX tracks — one <Audio> per plan.sfx[] entry.
            File names are resolved by build_remotion.py (category → concrete file
            via sfx_index.json seeded with reel name + category + index, then copied
            to public/sfx/). Volume converts dB → linear; duration cap from
            SFX_DURATION_CAPS_MS prevents long risers from running over the next SFX. */}
      {(plan.sfx ?? []).map((sfx, i) => {
        if (!sfx.file) return null;
        const startFrame = Math.round((sfx.at_ms / 1000) * fps);
        const capMs = sfx.duration_ms ?? sfx.duration_cap_ms;
        const durationFrames = capMs
          ? Math.max(1, Math.round((capMs / 1000) * fps))
          : undefined;
        const volume = dbToLinear(sfx.volume_db ?? -10);
        return (
          <Sequence
            key={`sfx-${i}-${sfx.category}`}
            from={startFrame}
            durationInFrames={durationFrames}
          >
            <Audio src={staticFile(`sfx/${sfx.file}`)} volume={volume} />
          </Sequence>
        );
      })}

      {/* ── Music tracks (optional) — background tracks via plan.music[].
            Files live in public/music/ (build_remotion.py does NOT auto-copy these —
            place them manually or extend the resolver). */}
      {(plan.music ?? []).map((m, i) => {
        const startFrame = Math.round(((m.start_ms ?? 0) / 1000) * fps);
        const durationFrames = m.end_ms
          ? Math.max(1, Math.round(((m.end_ms - (m.start_ms ?? 0)) / 1000) * fps))
          : undefined;
        const volume = dbToLinear(m.volume_db ?? -18);
        return (
          <Sequence
            key={`music-${i}`}
            from={startFrame}
            durationInFrames={durationFrames}
          >
            <Audio src={staticFile(`music/${m.file}`)} volume={volume} />
          </Sequence>
        );
      })}
    </AbsoluteFill>
  );
};
