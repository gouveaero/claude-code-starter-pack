import React from "react";
import { Composition, Still } from "remotion";
import { z } from "zod";
import { zColor } from "@remotion/zod-types";
import { Reel } from "./Reel";
import { ReelThumbnail } from "./ReelThumbnail";
import editPlan from "./edit_plan.json";
import brandConfig from "./brand_config.json";
import { preloadCommonFonts } from "./components/fonts";

// Auto-generated by build_remotion.py — do not edit by hand.
// To regenerate: python3 ~/.claude/skills/video-editor/scripts/build_remotion.py
//                  --plan <output>/edit_plan.json --remotion-dir <output>/remotion

// Preload Google Fonts so they're bundled before any frame renders.
preloadCommonFonts();

// Zod schema — drives Studio UI controls + runtime validation.
// Components receive validated, typed props. Wrong types fail fast in dev.
const reelPropsSchema = z.object({
  plan: z.any(),
  brand: z.any(),
  // Per-render overrides (passed via --props from batch_data_driven.py / preview_player.py):
  title: z.string().optional(),
  hookText: z.string().optional(),
  brandColor: zColor().optional(),
  captionStyle: z.enum(["tiktok", "broadcast", "minimal"]).optional(),
  durationMs: z.number().min(1000).max(600000).optional(),
});

const thumbnailPropsSchema = z.object({
  plan: z.any(),
  brand: z.any(),
  frameIndex: z.number().optional(),
  title: z.string().optional(),
});

export const RemotionRoot: React.FC = () => {
  return (
    <>
      <Composition
        id="Reel"
        component={Reel as any}
        schema={reelPropsSchema}
        defaultProps={{
          plan: editPlan as any,
          brand: brandConfig as any,
        }}
        fps={{{FPS}}}
        width={{{WIDTH}}}
        height={{{HEIGHT}}}
        // calculateMetadata derives duration from props at render time.
        // Required for data-driven videos (CSV → N reels) where each row has its own duration.
        calculateMetadata={({ props }) => {
          const planObj = props.plan as any;
          // Priority: explicit durationMs > plan total_duration_ms > template default
          const ms =
            props.durationMs ??
            (planObj?.total_duration_ms as number | undefined) ??
            {{DURATION_MS_DEFAULT}};
          return {
            durationInFrames: Math.max(1, Math.ceil((ms / 1000) * {{FPS}})),
          };
        }}
      />

      {/* Static thumbnail composition — renders one frame of the reel as Instagram/YouTube cover.
          Use:  npx remotion still reel-thumbnail thumb.png --props='{"frameIndex":2400}'
          Or:   python scripts/render_thumbnail.py --frame-ms 80000 */}
      <Still
        id="reel-thumbnail"
        component={ReelThumbnail as any}
        schema={thumbnailPropsSchema}
        defaultProps={{
          plan: editPlan as any,
          brand: brandConfig as any,
          frameIndex: 0,
        }}
        width={{{WIDTH}}}
        height={{{HEIGHT}}}
      />
    </>
  );
};
